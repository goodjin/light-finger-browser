build ./base_profiler_test_support_library.so ./base_profiler_test_support_library.so.dSYM/Contents/Info.plist ./base_profiler_test_support_library.so.dSYM/Contents/Resources/DWARF/base_profiler_test_support_library.so: solink_module obj/base/base_profiler_test_support_library/test_support_library.o | ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt ||
