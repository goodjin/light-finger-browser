build obj/base/allocator/partition_allocator/src/partition_alloc/libraw_ptr.a: alink obj/base/allocator/partition_allocator/src/partition_alloc/raw_ptr/instance_tracer.o obj/base/allocator/partition_allocator/src/partition_alloc/raw_ptr/raw_ptr_backup_ref_impl.o | ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a phony/base/allocator/partition_allocator/src/partition_alloc/raw_ptr.inputs || phony/base/allocator/partition_allocator/src/partition_alloc/build_config phony/base/allocator/partition_allocator/src/partition_alloc/buildflags phony/base/allocator/partition_allocator/src/partition_alloc/partition_alloc obj/base/allocator/partition_allocator/src/partition_alloc/liballocator_base.a obj/base/allocator/partition_allocator/src/partition_alloc/liballocator_core.a obj/base/allocator/partition_allocator/src/partition_alloc/liballocator_shim.a
  arflags = -T -s
  output_extension = .a
  output_dir = obj/base/allocator/partition_allocator/src/partition_alloc
