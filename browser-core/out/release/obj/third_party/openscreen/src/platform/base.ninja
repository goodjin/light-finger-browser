build phony/third_party/openscreen/src/platform/base: phony obj/third_party/openscreen/src/platform/base/error.o obj/third_party/openscreen/src/platform/base/interface_info.o obj/third_party/openscreen/src/platform/base/ip_address.o obj/third_party/openscreen/src/platform/base/location.o obj/third_party/openscreen/src/platform/base/tls_credentials.o obj/third_party/openscreen/src/platform/base/trace_logging_activation.o obj/third_party/openscreen/src/platform/base/trace_logging_types.o obj/third_party/openscreen/src/platform/base/trivial_clock_traits.o obj/third_party/openscreen/src/platform/base/udp_packet.o
