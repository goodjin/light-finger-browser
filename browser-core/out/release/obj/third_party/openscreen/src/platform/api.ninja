build phony/third_party/openscreen/src/platform/api: phony obj/third_party/openscreen/src/platform/api/task_runner_deleter.o obj/third_party/openscreen/src/platform/api/tls_connection.o obj/third_party/openscreen/src/platform/api/tls_connection_factory.o obj/third_party/openscreen/src/platform/api/trace_event.o obj/third_party/openscreen/src/platform/api/trace_logging_platform.o obj/third_party/openscreen/src/platform/api/udp_socket.o || phony/third_party/openscreen/src/platform/base phony/third_party/openscreen/src/platform/logging
