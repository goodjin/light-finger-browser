defines = -DOFFICIAL_BUILD -D__STDC_CONSTANT_MACROS -D__STDC_FORMAT_MACROS -D_FORTIFY_SOURCE=2 -D__ARM_NEON__=1 -DCR_XCODE_VERSION=2650 -DCR_CLANG_REVISION=\"llvmorg-21-init-5118-g52cd27e6-5\" -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE -D_LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCPP_INSTRUMENTED_WITH_ASAN=0 -DCR_LIBCXX_REVISION=449310fe2e37834a7e62972d2a690cade2ef596b -DTMP_REBUILD_HACK -DNDEBUG -DNVALGRIND -DDYNAMIC_ANNOTATIONS_ENABLED=0 -DWITHOUT_OPEN_MEMSTREAM
framework_dirs =
include_dirs = -I../../src -Igen -I../../src/buildtools/third_party/libc++
cflags = -Wall -Wextra -Wimplicit-fallthrough -Wextra-semi -Wunreachable-code-aggressive -Wthread-safety -Wgnu -Wno-gnu-anonymous-struct -Wno-gnu-conditional-omitted-operand -Wno-gnu-include-next -Wno-gnu-label-as-value -Wno-gnu-redeclared-enum -Wno-gnu-statement-expression -Wno-gnu-zero-variadic-macro-arguments -Wno-zero-length-array -Wunguarded-availability -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wno-cast-function-type -Wno-thread-safety-reference-return -Wno-nontrivial-memcall -Wshadow -fno-delete-null-pointer-checks -fno-strict-overflow -fno-ident -fno-strict-aliasing -fstack-protector -fcolor-diagnostics -fmerge-all-constants -fno-sized-deallocation -fcrash-diagnostics-dir=../../src/tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -mllvm -split-threshold-for-reg-with-hint=0 -ffp-contract=off -fcomplete-member-pointers --target=arm64-apple-macos -mno-outline -no-canonical-prefixes -Xclang --warning-suppression-mappings=../../src/build/config/warning_suppression.txt -ftrivial-auto-var-init=pattern -O2 -fno-math-errno -fno-omit-frame-pointer -fno-standalone-debug -g2 -gdwarf-aranges -Xclang -debug-info-kind=limited -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -fvisibility=hidden -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang span-ctor-from-string-literal -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang raw-span-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-stack-allocated -Xclang -add-plugin -Xclang raw-ptr-plugin -Xclang -plugin-arg-raw-ptr-plugin -Xclang check-raw-ptr-to-stack-allocated -Xclang -plugin-arg-raw-ptr-plugin -Xclang disable-check-raw-ptr-to-stack-allocated-error -Xclang -plugin-arg-raw-ptr-plugin -Xclang raw-ptr-exclude-path=../../src/third_party/dawn/ -DUNSAFE_BUFFERS_BUILD -Xclang -add-plugin -Xclang unsafe-buffers -Xclang -plugin-arg-unsafe-buffers -Xclang ../../src/build/config/unsafe_buffers_paths.txt -w
cflags_c = -std=c11
label_name = tinycbor
root_out_dir = .
target_out_dir = obj/third_party/openscreen/src/third_party/tinycbor
target_output_name = tinycbor

build phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs: phony ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborencoder.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborencoder.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborencoder.c
  source_name_part = cborencoder
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborencoder_close_container_checked.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborencoder_close_container_checked.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborencoder_close_container_checked.c
  source_name_part = cborencoder_close_container_checked
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborerrorstrings.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborerrorstrings.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborerrorstrings.c
  source_name_part = cborerrorstrings
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborparser.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborparser.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborparser.c
  source_name_part = cborparser
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborpretty.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborpretty.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborpretty.c
  source_name_part = cborpretty
build obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborvalidation.o: cc ../../src/third_party/openscreen/src/third_party/tinycbor/src/src/cborvalidation.c | phony/third_party/openscreen/src/third_party/tinycbor/tinycbor.inputs
  source_file_part = cborvalidation.c
  source_name_part = cborvalidation

build phony/third_party/openscreen/src/third_party/tinycbor/tinycbor: phony obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborencoder.o obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborencoder_close_container_checked.o obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborerrorstrings.o obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborparser.o obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborpretty.o obj/third_party/openscreen/src/third_party/tinycbor/tinycbor/cborvalidation.o
