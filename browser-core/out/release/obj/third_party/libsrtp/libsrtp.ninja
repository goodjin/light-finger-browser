build obj/third_party/libsrtp/libsrtp/crypto_kernel.o: cc ../../src/third_party/libsrtp/crypto/kernel/crypto_kernel.c | phony/third_party/libsrtp/libsrtp.inputs
  source_file_part = crypto_kernel.c
