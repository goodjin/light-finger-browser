defines = -DOFFICIAL_BUILD -D__ARM_NEON__=1 -DCR_XCODE_VERSION=2650 -DCR_CLANG_REVISION=\"llvmorg-21-init-5118-g52cd27e6-5\" -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE -D_LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCPP_INSTRUMENTED_WITH_ASAN=0 -DCR_LIBCXX_REVISION=449310fe2e37834a7e62972d2a690cade2ef596b -DTMP_REBUILD_HACK -DNDEBUG -DNVALGRIND -DDYNAMIC_ANNOTATIONS_ENABLED=0 -DZ7_LZMA_PROB32 -DZ7_NO_METHODS_FILTERS -DZ7_ST -D_LZMA_PROB32
framework_dirs =
include_dirs = -I../../src -Igen -I../../src/buildtools/third_party/libc++ -I../../src/third_party/lzma_sdk -I../../src/third_party/lzma_sdk/C
cflags = -fno-delete-null-pointer-checks -fno-strict-overflow -fno-ident -fno-strict-aliasing -fstack-protector -fcolor-diagnostics -fmerge-all-constants -fno-sized-deallocation -fcrash-diagnostics-dir=../../src/tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -mllvm -split-threshold-for-reg-with-hint=0 -ffp-contract=off -fcomplete-member-pointers --target=arm64-apple-macos -mno-outline -no-canonical-prefixes -Xclang --warning-suppression-mappings=../../src/build/config/warning_suppression.txt -ftrivial-auto-var-init=pattern -O2 -fno-math-errno -fno-omit-frame-pointer -fno-standalone-debug -g2 -gdwarf-aranges -Xclang -debug-info-kind=limited -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -fvisibility=hidden -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang span-ctor-from-string-literal -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang raw-span-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-stack-allocated -Xclang -add-plugin -Xclang raw-ptr-plugin -Xclang -plugin-arg-raw-ptr-plugin -Xclang check-raw-ptr-to-stack-allocated -Xclang -plugin-arg-raw-ptr-plugin -Xclang disable-check-raw-ptr-to-stack-allocated-error -Xclang -plugin-arg-raw-ptr-plugin -Xclang raw-ptr-exclude-path=../../src/third_party/dawn/ -DUNSAFE_BUFFERS_BUILD -Xclang -add-plugin -Xclang unsafe-buffers -Xclang -plugin-arg-unsafe-buffers -Xclang ../../src/build/config/unsafe_buffers_paths.txt -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wunguarded-availability -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wno-cast-function-type -Wno-thread-safety-reference-return -Wno-nontrivial-memcall -Wno-self-assign
cflags_c = -std=c11
label_name = lzma_sdk_xz
root_out_dir = .
target_out_dir = obj/third_party/lzma_sdk
target_output_name = liblzma_sdk_xz

build phony/third_party/lzma_sdk/lzma_sdk_xz.inputs: phony ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt
build obj/third_party/lzma_sdk/lzma_sdk_xz/BraIA64.o: cc ../../src/third_party/lzma_sdk/C/BraIA64.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = BraIA64.c
  source_name_part = BraIA64
build obj/third_party/lzma_sdk/lzma_sdk_xz/Sha256.o: cc ../../src/third_party/lzma_sdk/C/Sha256.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = Sha256.c
  source_name_part = Sha256
build obj/third_party/lzma_sdk/lzma_sdk_xz/Sha256Opt.o: cc ../../src/third_party/lzma_sdk/C/Sha256Opt.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = Sha256Opt.c
  source_name_part = Sha256Opt
build obj/third_party/lzma_sdk/lzma_sdk_xz/Xz.o: cc ../../src/third_party/lzma_sdk/C/Xz.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = Xz.c
  source_name_part = Xz
build obj/third_party/lzma_sdk/lzma_sdk_xz/XzCrc64.o: cc ../../src/third_party/lzma_sdk/C/XzCrc64.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = XzCrc64.c
  source_name_part = XzCrc64
build obj/third_party/lzma_sdk/lzma_sdk_xz/XzCrc64Opt.o: cc ../../src/third_party/lzma_sdk/C/XzCrc64Opt.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = XzCrc64Opt.c
  source_name_part = XzCrc64Opt
build obj/third_party/lzma_sdk/lzma_sdk_xz/XzDec.o: cc ../../src/third_party/lzma_sdk/C/XzDec.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = XzDec.c
  source_name_part = XzDec
build obj/third_party/lzma_sdk/lzma_sdk_xz/XzIn.o: cc ../../src/third_party/lzma_sdk/C/XzIn.c | phony/third_party/lzma_sdk/lzma_sdk_xz.inputs
  source_file_part = XzIn.c
  source_name_part = XzIn

build obj/third_party/lzma_sdk/liblzma_sdk_xz.a: alink obj/third_party/lzma_sdk/lzma_sdk_xz/BraIA64.o obj/third_party/lzma_sdk/lzma_sdk_xz/Sha256.o obj/third_party/lzma_sdk/lzma_sdk_xz/Sha256Opt.o obj/third_party/lzma_sdk/lzma_sdk_xz/Xz.o obj/third_party/lzma_sdk/lzma_sdk_xz/XzCrc64.o obj/third_party/lzma_sdk/lzma_sdk_xz/XzCrc64Opt.o obj/third_party/lzma_sdk/lzma_sdk_xz/XzDec.o obj/third_party/lzma_sdk/lzma_sdk_xz/XzIn.o | ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a phony/third_party/lzma_sdk/lzma_sdk_xz.inputs || obj/third_party/lzma_sdk/liblzma_sdk.a
  arflags = -T -s
  output_extension = .a
  output_dir = obj/third_party/lzma_sdk
