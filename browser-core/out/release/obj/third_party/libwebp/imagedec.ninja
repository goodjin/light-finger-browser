  source_file_part = tiffdec.c
  source_name_part = tiffdec
build obj/third_party/libwebp/imagedec/webpdec.o: cc ../../src/third_party/libwebp/src/imageio/webpdec.c | phony/third_party/libwebp/imagedec.inputs
