build phony/third_party/libwebp/imagedec: phony obj/third_party/libwebp/imagedec/image_dec.o obj/third_party/libwebp/imagedec/jpegdec.o obj/third_party/libwebp/imagedec/metadata.o obj/third_party/libwebp/imagedec/pngdec.o obj/third_party/libwebp/imagedec/pnmdec.o obj/third_party/libwebp/imagedec/tiffdec.o obj/third_party/libwebp/imagedec/webpdec.o obj/third_party/libwebp/imagedec/wicdec.o || phony/third_party/libwebp/imageio_util phony/third_party/libpng/libpng obj/third_party/zlib/libchrome_zlib.a phony/third_party/libpng/libpng_sources phony/third_party/zlib/zlib_adler32_simd phony/third_party/zlib/zlib_inflate_chunk_simd phony/third_party/zlib/zlib_arm_crc32
