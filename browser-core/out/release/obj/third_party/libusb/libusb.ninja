defines = -DDEFAULT_VISIBILITY= -DHAVE_GETTIMEOFDAY=1 -DHAVE_POLL_H=1 -DHAVE_SYS_TIME_H=1 -DLIBUSB_DESCRIBE=\"1.0.16\" -DPOLL_NFDS_TYPE=nfds_t -DTHREADS_POSIX=1 -DOS_DARWIN=1 -DOBJC_SILENCE_GC_DEPRECATIONS=1 -DOFFICIAL_BUILD -D__ARM_NEON__=1 -DCR_XCODE_VERSION=2650 -DCR_CLANG_REVISION=\"llvmorg-21-init-5118-g52cd27e6-5\" -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE -D_LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCPP_INSTRUMENTED_WITH_ASAN=0 -DCR_LIBCXX_REVISION=449310fe2e37834a7e62972d2a690cade2ef596b -DTMP_REBUILD_HACK -DNDEBUG -DNVALGRIND -DDYNAMIC_ANNOTATIONS_ENABLED=0
framework_dirs =
include_dirs = -I../../src/third_party/libusb/src/libusb/os -I../../src/third_party/libusb/src -I../../src -Igen -I../../src/buildtools/third_party/libc++ -I../../src/third_party/libusb/src/libusb
cflags = -fno-delete-null-pointer-checks -fno-strict-overflow -fno-ident -fno-strict-aliasing -fstack-protector -fcolor-diagnostics -fmerge-all-constants -fno-sized-deallocation -fcrash-diagnostics-dir=../../src/tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -mllvm -split-threshold-for-reg-with-hint=0 -ffp-contract=off -fcomplete-member-pointers --target=arm64-apple-macos -mno-outline -no-canonical-prefixes -Xclang --warning-suppression-mappings=../../src/build/config/warning_suppression.txt -ftrivial-auto-var-init=pattern -O2 -fno-math-errno -fno-omit-frame-pointer -fno-standalone-debug -g2 -gdwarf-aranges -Xclang -debug-info-kind=limited -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -fvisibility=hidden -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang span-ctor-from-string-literal -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang raw-span-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-stack-allocated -Xclang -add-plugin -Xclang raw-ptr-plugin -Xclang -plugin-arg-raw-ptr-plugin -Xclang check-raw-ptr-to-stack-allocated -Xclang -plugin-arg-raw-ptr-plugin -Xclang disable-check-raw-ptr-to-stack-allocated-error -Xclang -plugin-arg-raw-ptr-plugin -Xclang raw-ptr-exclude-path=../../src/third_party/dawn/ -DUNSAFE_BUFFERS_BUILD -Xclang -add-plugin -Xclang unsafe-buffers -Xclang -plugin-arg-unsafe-buffers -Xclang ../../src/build/config/unsafe_buffers_paths.txt -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wunguarded-availability -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wno-cast-function-type -Wno-thread-safety-reference-return -Wno-nontrivial-memcall -Wno-unused-function
cflags_c = -std=c11
label_name = libusb
root_out_dir = .
target_out_dir = obj/third_party/libusb
target_output_name = libusb

build phony/third_party/libusb/libusb.inputs: phony ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt
build obj/third_party/libusb/libusb/core.o: cc ../../src/third_party/libusb/src/libusb/core.c | phony/third_party/libusb/libusb.inputs
  source_file_part = core.c
  source_name_part = core
build obj/third_party/libusb/libusb/descriptor.o: cc ../../src/third_party/libusb/src/libusb/descriptor.c | phony/third_party/libusb/libusb.inputs
  source_file_part = descriptor.c
  source_name_part = descriptor
build obj/third_party/libusb/libusb/hotplug.o: cc ../../src/third_party/libusb/src/libusb/hotplug.c | phony/third_party/libusb/libusb.inputs
  source_file_part = hotplug.c
  source_name_part = hotplug
build obj/third_party/libusb/libusb/interrupt.o: cc ../../src/third_party/libusb/src/libusb/interrupt.c | phony/third_party/libusb/libusb.inputs
  source_file_part = interrupt.c
  source_name_part = interrupt
build obj/third_party/libusb/libusb/io.o: cc ../../src/third_party/libusb/src/libusb/io.c | phony/third_party/libusb/libusb.inputs
  source_file_part = io.c
  source_name_part = io
build obj/third_party/libusb/libusb/darwin_usb.o: cc ../../src/third_party/libusb/src/libusb/os/darwin_usb.c | phony/third_party/libusb/libusb.inputs
  source_file_part = darwin_usb.c
  source_name_part = darwin_usb
build obj/third_party/libusb/libusb/poll_posix.o: cc ../../src/third_party/libusb/src/libusb/os/poll_posix.c | phony/third_party/libusb/libusb.inputs
  source_file_part = poll_posix.c
  source_name_part = poll_posix
build obj/third_party/libusb/libusb/threads_posix.o: cc ../../src/third_party/libusb/src/libusb/os/threads_posix.c | phony/third_party/libusb/libusb.inputs
  source_file_part = threads_posix.c
  source_name_part = threads_posix
build obj/third_party/libusb/libusb/strerror.o: cc ../../src/third_party/libusb/src/libusb/strerror.c | phony/third_party/libusb/libusb.inputs
  source_file_part = strerror.c
  source_name_part = strerror
build obj/third_party/libusb/libusb/sync.o: cc ../../src/third_party/libusb/src/libusb/sync.c | phony/third_party/libusb/libusb.inputs
  source_file_part = sync.c
  source_name_part = sync

build obj/third_party/libusb/libusb.a: alink obj/third_party/libusb/libusb/core.o obj/third_party/libusb/libusb/descriptor.o obj/third_party/libusb/libusb/hotplug.o obj/third_party/libusb/libusb/interrupt.o obj/third_party/libusb/libusb/io.o obj/third_party/libusb/libusb/darwin_usb.o obj/third_party/libusb/libusb/poll_posix.o obj/third_party/libusb/libusb/threads_posix.o obj/third_party/libusb/libusb/strerror.o obj/third_party/libusb/libusb/sync.o | ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a phony/third_party/libusb/libusb.inputs ||
  arflags = -T -s
  output_extension = .a
  output_dir = obj/third_party/libusb
