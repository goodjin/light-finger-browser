defines = -DOFFICIAL_BUILD -D__ARM_NEON__=1 -DCR_XCODE_VERSION=2650 -DCR_CLANG_REVISION=\"llvmorg-21-init-5118-g52cd27e6-5\" -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE -D_LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCPP_INSTRUMENTED_WITH_ASAN=0 -DCR_LIBCXX_REVISION=449310fe2e37834a7e62972d2a690cade2ef596b -DTMP_REBUILD_HACK -DNDEBUG -DNVALGRIND -DDYNAMIC_ANNOTATIONS_ENABLED=0 -DREACTOR_ANONYMOUS_MMAP_NAME=swiftshader_jit
framework_dirs =
include_dirs = -I../../src -Igen -I../../src/buildtools/third_party/libc++
cflags = -fno-delete-null-pointer-checks -fno-strict-overflow -fno-ident -fno-strict-aliasing -fstack-protector -fcolor-diagnostics -fmerge-all-constants -fno-sized-deallocation -fcrash-diagnostics-dir=../../src/tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -mllvm -split-threshold-for-reg-with-hint=0 -ffp-contract=off -fcomplete-member-pointers --target=arm64-apple-macos -mno-outline -no-canonical-prefixes -Xclang --warning-suppression-mappings=../../src/build/config/warning_suppression.txt -ftrivial-auto-var-init=pattern -O2 -fno-math-errno -fno-omit-frame-pointer -fno-standalone-debug -g2 -gdwarf-aranges -Xclang -debug-info-kind=limited -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -fvisibility=hidden -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang span-ctor-from-string-literal -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang raw-span-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-stack-allocated -Xclang -add-plugin -Xclang raw-ptr-plugin -Xclang -plugin-arg-raw-ptr-plugin -Xclang check-raw-ptr-to-stack-allocated -Xclang -plugin-arg-raw-ptr-plugin -Xclang disable-check-raw-ptr-to-stack-allocated-error -Xclang -plugin-arg-raw-ptr-plugin -Xclang raw-ptr-exclude-path=../../src/third_party/dawn/ -DUNSAFE_BUFFERS_BUILD -Xclang -add-plugin -Xclang unsafe-buffers -Xclang -plugin-arg-unsafe-buffers -Xclang ../../src/build/config/unsafe_buffers_paths.txt -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wunguarded-availability -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wno-cast-function-type -Wno-thread-safety-reference-return -Wno-nontrivial-memcall -Wno-shadow -Os
cflags_cc = -std=c++20 -Wno-trigraphs -fno-exceptions -fno-rtti -nostdinc++ -isystem../../src/third_party/libc++/src/include -isystem../../src/third_party/libc++abi/src/include -fvisibility-inlines-hidden -Wno-invalid-offsetof -Wenum-compare-conditional -Wno-nullability-completeness
label_name = swiftshader_reactor_base
root_out_dir = .
target_out_dir = obj/third_party/swiftshader/src/Reactor
target_output_name = swiftshader_reactor_base

build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Assert.o: cxx ../../src/third_party/swiftshader/src/Reactor/Assert.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = Assert.cpp
  source_name_part = Assert
build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Debug.o: cxx ../../src/third_party/swiftshader/src/Reactor/Debug.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = Debug.cpp
  source_name_part = Debug
build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/ExecutableMemory.o: cxx ../../src/third_party/swiftshader/src/Reactor/ExecutableMemory.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = ExecutableMemory.cpp
  source_name_part = ExecutableMemory
build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Pragma.o: cxx ../../src/third_party/swiftshader/src/Reactor/Pragma.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = Pragma.cpp
  source_name_part = Pragma
build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Reactor.o: cxx ../../src/third_party/swiftshader/src/Reactor/Reactor.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = Reactor.cpp
  source_name_part = Reactor
build obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/SIMD.o: cxx ../../src/third_party/swiftshader/src/Reactor/SIMD.cpp | ../../src/build/config/warning_suppression.txt
  source_file_part = SIMD.cpp
  source_name_part = SIMD

build phony/third_party/swiftshader/src/Reactor/swiftshader_reactor_base: phony obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Assert.o obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Debug.o obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/ExecutableMemory.o obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Pragma.o obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/Reactor.o obj/third_party/swiftshader/src/Reactor/swiftshader_reactor_base/SIMD.o
