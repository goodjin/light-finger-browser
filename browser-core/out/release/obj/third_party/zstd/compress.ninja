build phony/third_party/zstd/compress: phony obj/third_party/zstd/compress/fse_compress.o obj/third_party/zstd/compress/hist.o obj/third_party/zstd/compress/huf_compress.o obj/third_party/zstd/compress/zstd_compress.o obj/third_party/zstd/compress/zstd_compress_literals.o obj/third_party/zstd/compress/zstd_compress_sequences.o obj/third_party/zstd/compress/zstd_compress_superblock.o obj/third_party/zstd/compress/zstd_double_fast.o obj/third_party/zstd/compress/zstd_fast.o obj/third_party/zstd/compress/zstd_lazy.o obj/third_party/zstd/compress/zstd_ldm.o obj/third_party/zstd/compress/zstd_opt.o obj/third_party/zstd/compress/zstd_preSplit.o obj/third_party/zstd/compress/zstdmt_compress.o || phony/third_party/zstd/common
