defines = -DOFFICIAL_BUILD -D__ARM_NEON__=1 -DCR_XCODE_VERSION=2650 -DCR_CLANG_REVISION=\"llvmorg-21-init-5118-g52cd27e6-5\" -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE -D_LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCXXABI_DISABLE_VISIBILITY_ANNOTATIONS -D_LIBCPP_INSTRUMENTED_WITH_ASAN=0 -DCR_LIBCXX_REVISION=449310fe2e37834a7e62972d2a690cade2ef596b -DTMP_REBUILD_HACK -DNDEBUG -DNVALGRIND -DDYNAMIC_ANNOTATIONS_ENABLED=0 -DZSTDLIB_STATIC_API=ZSTDLIB_HIDDEN -DZDICTLIB_STATIC_API=ZDICTLIB_HIDDEN -DZSTDLIB_VISIBLE=ZSTDLIB_HIDDEN -DZSTDERRORLIB_VISIBLE=ZSTDERRORLIB_HIDDEN -DZDICTLIB_VISIBLE=ZDICTLIB_HIDDEN
framework_dirs =
include_dirs = -I../../src -Igen -I../../src/buildtools/third_party/libc++
cflags = -fno-delete-null-pointer-checks -fno-strict-overflow -fno-ident -fno-strict-aliasing -fstack-protector -fcolor-diagnostics -fmerge-all-constants -fno-sized-deallocation -fcrash-diagnostics-dir=../../src/tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -mllvm -split-threshold-for-reg-with-hint=0 -ffp-contract=off -fcomplete-member-pointers --target=arm64-apple-macos -mno-outline -no-canonical-prefixes -Xclang --warning-suppression-mappings=../../src/build/config/warning_suppression.txt -ftrivial-auto-var-init=pattern -fno-omit-frame-pointer -fno-standalone-debug -g2 -gdwarf-aranges -Xclang -debug-info-kind=limited -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -fvisibility=hidden -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang span-ctor-from-string-literal -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang raw-span-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-stack-allocated -Xclang -add-plugin -Xclang raw-ptr-plugin -Xclang -plugin-arg-raw-ptr-plugin -Xclang check-raw-ptr-to-stack-allocated -Xclang -plugin-arg-raw-ptr-plugin -Xclang disable-check-raw-ptr-to-stack-allocated-error -Xclang -plugin-arg-raw-ptr-plugin -Xclang raw-ptr-exclude-path=../../src/third_party/dawn/ -DUNSAFE_BUFFERS_BUILD -Xclang -add-plugin -Xclang unsafe-buffers -Xclang -plugin-arg-unsafe-buffers -Xclang ../../src/build/config/unsafe_buffers_paths.txt -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wunguarded-availability -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wno-cast-function-type -Wno-thread-safety-reference-return -Wno-nontrivial-memcall -O3 -fno-math-errno
cflags_c = -std=c11
label_name = common
root_out_dir = .
target_out_dir = obj/third_party/zstd
target_output_name = common

build phony/third_party/zstd/common.inputs: phony ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt
build obj/third_party/zstd/common/debug.o: cc ../../src/third_party/zstd/src/lib/common/debug.c | phony/third_party/zstd/common.inputs
  source_file_part = debug.c
  source_name_part = debug
build obj/third_party/zstd/common/entropy_common.o: cc ../../src/third_party/zstd/src/lib/common/entropy_common.c | phony/third_party/zstd/common.inputs
  source_file_part = entropy_common.c
  source_name_part = entropy_common
build obj/third_party/zstd/common/error_private.o: cc ../../src/third_party/zstd/src/lib/common/error_private.c | phony/third_party/zstd/common.inputs
  source_file_part = error_private.c
  source_name_part = error_private
build obj/third_party/zstd/common/fse_decompress.o: cc ../../src/third_party/zstd/src/lib/common/fse_decompress.c | phony/third_party/zstd/common.inputs
  source_file_part = fse_decompress.c
  source_name_part = fse_decompress
build obj/third_party/zstd/common/pool.o: cc ../../src/third_party/zstd/src/lib/common/pool.c | phony/third_party/zstd/common.inputs
  source_file_part = pool.c
  source_name_part = pool
build obj/third_party/zstd/common/threading.o: cc ../../src/third_party/zstd/src/lib/common/threading.c | phony/third_party/zstd/common.inputs
  source_file_part = threading.c
  source_name_part = threading
build obj/third_party/zstd/common/xxhash.o: cc ../../src/third_party/zstd/src/lib/common/xxhash.c | phony/third_party/zstd/common.inputs
  source_file_part = xxhash.c
  source_name_part = xxhash
build obj/third_party/zstd/common/zstd_common.o: cc ../../src/third_party/zstd/src/lib/common/zstd_common.c | phony/third_party/zstd/common.inputs
  source_file_part = zstd_common.c
  source_name_part = zstd_common

build phony/third_party/zstd/common: phony obj/third_party/zstd/common/debug.o obj/third_party/zstd/common/entropy_common.o obj/third_party/zstd/common/error_private.o obj/third_party/zstd/common/fse_decompress.o obj/third_party/zstd/common/pool.o obj/third_party/zstd/common/threading.o obj/third_party/zstd/common/xxhash.o obj/third_party/zstd/common/zstd_common.o
