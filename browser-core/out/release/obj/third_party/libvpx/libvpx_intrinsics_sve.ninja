build phony/third_party/libvpx/libvpx_intrinsics_sve: phony obj/third_party/libvpx/libvpx_intrinsics_sve/vp9_error_sve.o obj/third_party/libvpx/libvpx_intrinsics_sve/highbd_variance_sve.o obj/third_party/libvpx/libvpx_intrinsics_sve/highbd_vpx_convolve8_sve.o obj/third_party/libvpx/libvpx_intrinsics_sve/sum_squares_sve.o
