build obj/chrome/installer/mac/third_party/bsdiff/goobspatch/goobspatch.o: cc ../../src/chrome/installer/mac/third_party/bsdiff/goobspatch.c | ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt
  source_file_part = goobspatch.c
  source_name_part = goobspatch

build ./goobspatch ./goobspatch.dSYM/Contents/Info.plist ./goobspatch.dSYM/Contents/Resources/DWARF/goobspatch: link obj/chrome/installer/mac/third_party/bsdiff/goobspatch/goobspatch.o | ./liblzma_decompress.dylib.TOC ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a ../../src/build/config/unsafe_buffers_paths.txt ../../src/build/config/warning_suppression.txt ||
  ldflags = -fuse-ld=lld -Wl,-fatal_warnings -Wl,--icf=all -Wl,--color-diagnostics -Wl,--strict-auto-link -Wl,--no-call-graph-profile-sort --target=arm64-apple-macos -Wl,-mllvm,-enable-machine-outliner=never -no-canonical-prefixes -Wl,-dead_strip -Wl,-no_data_in_code_info -Wl,-no_function_starts -nostdlib++ -isysroot ../../../../../../../Applications/Xcode-beta.app/Contents/Developer/Platforms/MacOSX.platform/Developer/SDKs/MacOSX26.5.sdk -mmacos-version-min=11.0 -Wl,-ObjC -Wcrl,strip,-x,-S -Wl,--no-warn-duplicate-rpath -Wl,-no_warn_duplicate_libraries
  libs = -lbz2 -lz ../../src/third_party/llvm-build/Release+Asserts/lib/clang/21/lib/darwin/libclang_rt.osx.a
  frameworks =
  swiftmodules =
  output_extension =
