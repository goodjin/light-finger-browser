output_dir = clang_arm64_for_rust_host_build_tools/obj/build/rust/chromium_prelude
rustflags = --edition=2021 -Cdebug-assertions -Dunsafe_op_in_unsafe_fn -Csplit-debuginfo=unpacked -Cdefault-linker-libraries -Zdep-info-omit-d-target -Zmacro-backtrace -Zremap-cwd-prefix=. -Zexternal-clangrt --color=always --target=aarch64-apple-darwin -Cembed-bitcode=no -Clto=no --cfg cr_rustc_revision=\"f7b43542838f0a4a6cfdb17fbeadf45002042a77-1-llvmorg-21-init-5118-g52cd27e6\" -Copt-level=3 -Zdwarf-version=4 -g -Zallow-features= -Zdefault-visibility=hidden -Funsafe_code
rustenv = OUT_DIR=../../../../out/release/clang_arm64_for_rust_host_build_tools/gen/build/rust/chromium_prelude/chromium_prelude
label_name = chromium_prelude
root_out_dir = clang_arm64_for_rust_host_build_tools
target_out_dir = clang_arm64_for_rust_host_build_tools/obj/build/rust/chromium_prelude
target_output_name = chromium

build clang_arm64_for_rust_host_build_tools/obj/build/rust/chromium_prelude/libchromium.rlib: clang_arm64_for_rust_host_build_tools_rust_rlib ../../src/build/rust/chromium_prelude/chromium_prelude.rs | ../../src/build/rust/chromium_prelude/chromium_prelude.rs clang_arm64_for_rust_host_build_tools/libimport_attribute.dylib || clang_arm64_for_rust_host_build_tools/phony/build/rust/std/prebuilt_rustc_copy_to_sysroot clang_arm64_for_rust_host_build_tools/phony/third_party/rust/proc_macro2/v1/proc_macro2_lib_v1_build_script_output ../../src/build/config/warning_suppression.txt clang_arm64_for_rust_host_build_tools/phony/build/rust/chromium_prelude/import_attribute clang_arm64_for_rust_host_build_tools/phony/build/rust/std/std
  source_file_part = chromium_prelude.rs
