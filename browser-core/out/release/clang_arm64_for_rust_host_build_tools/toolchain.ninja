rule clang_arm64_for_rust_host_build_tools_alink
  command = rm -f ${out} && "../../src/third_party/llvm-build/Release+Asserts/bin/llvm-ar" ${arflags} -r -c -s -D ${out} @${out}.rsp
  description = AR ${out}
  rspfile = ${out}.rsp
  rspfile_content = ${in}
rule clang_arm64_for_rust_host_build_tools_solink
  command = TOOL_VERSION=1777987628 ../../src/build/toolchain/apple/linker_driver.py -Wcrl,otoolpath,/Applications/Xcode-beta.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/otool -Wcrl,nmpath,/Applications/Xcode-beta.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/nm -Wcrl,tocname,"${output_dir}/${target_output_name}${output_extension}.TOC" -Wcrl,driver,../../src/third_party/llvm-build/Release+Asserts/bin/clang++ -Wcrl,strippath,/Applications/Xcode-beta.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin/strip -Wcrl,installnametoolpath,../../src/third_party/llvm-build/Release+Asserts/bin/llvm-install-name-tool -shared  -Wcrl,dsym,${root_out_dir} -Wcrl,dsymutilpath,../../src/tools/clang/dsymutil/bin/dsymutil ${ldflags} -o "${output_dir}/${target_output_name}${output_extension}" "@${output_dir}/${target_output_name}${output_extension}.rsp" ${rlibs}
  description = SOLINK ${out}
