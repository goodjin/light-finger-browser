rule clang_arm64_for_rust_host_build_tools_copy
  command = ln -f ${in} ${out} 2>/dev/null || (rm -rf ${out} && cp -af ${in} ${out})
  description = COPY ${in} ${out}
rule clang_arm64_for_rust_host_build_tools_cxx_module
  command = ../../src/third_party/llvm-build/Release+Asserts/bin/clang++ -MMD -MF ${out}.d ${defines} ${include_dirs} ${cflags} ${cflags_cc} ${module_deps_no_self} -fmodule-name=${label_name} -c -x c++ -Xclang -emit-module ${in} -o ${out}
  description = CXX_MODULE ${out}
  depfile = ${out}.d
  deps = gcc
rule clang_arm64_for_rust_host_build_tools_objc
