+// Default network parameters when not specified via command line.
+constexpr int kDefaultRttMs = 100;
+constexpr double kDefaultDownlinkMbps = 10.0;
+constexpr char kDefaultEffectiveType[] = "4g";
+
+// Parse RTT value from command line switch.
+// Returns true if parsing succeeded and sets |value| accordingly.
+bool GetNetworkRttFromCommandLine(int* value) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  std::string rtt_str = command_line->GetSwitchValueASCII("network-rtt");
+  if (rtt_str.empty()) {
+    return false;
+  }
+  // Parse as integer milliseconds.
+  int parsed_value = 0;
+  if (!base::StringToInt(rtt_str, &parsed_value)) {
+    return false;
+  }
+  // Clamp to reasonable range [0, 3000ms].
+  if (parsed_value < 0) {
+    parsed_value = 0;
+  } else if (parsed_value > 3000) {
+    parsed_value = 3000;
+  }
+  *value = parsed_value;
+  return true;
+}
+
+// Parse downlink bandwidth from command line switch.
+// Returns true if parsing succeeded and sets |value| accordingly.
+bool GetNetworkDownlinkFromCommandLine(double* value) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  std::string downlink_str =
+      command_line->GetSwitchValueASCII("network-downlink");
+  if (downlink_str.empty()) {
+    return false;
+  }
+  // Parse as double Mbps.
+  double parsed_value = 0.0;
+  if (!base::StringToDouble(downlink_str, &parsed_value)) {
+    return false;
+  }
+  // Clamp to reasonable range [0, 1000 Mbps].
+  if (parsed_value < 0.0) {
+    parsed_value = 0.0;
+  } else if (parsed_value > 1000.0) {
+    parsed_value = 1000.0;
+  }
+  *value = parsed_value;
+  return true;
+}
+
+// Parse effective type from command line switch.
+// Returns true if parsing succeeded and sets |value| accordingly.
+bool GetNetworkEffectiveTypeFromCommandLine(String* value) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  std::string effective_type_str =
+      base::ToLowerASCII(command_line->GetSwitchValueASCII("network-effective-type"));
+  if (effective_type_str.empty()) {
+    return false;
+  }
+  // Validate against allowed values: "slow-2g", "2g", "3g", "4g".
+  if (effective_type_str != "slow-2g" &&
+      effective_type_str != "2g" &&
+      effective_type_str != "3g" &&
+      effective_type_str != "4g") {
+    return false;
+  }
+  *value = String::FromUtf8(effective_type_str);
+  return true;
+}
+
+// Check if network information normalization is enabled.
+bool IsNetworkNormalizationEnabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  // Normalization is enabled by default when any network-related switch is present.
+  // Or explicitly via a dedicated switch.
+  if (command_line->HasSwitch("network-normalization")) {
+    std::string mode = base::ToLowerASCII(
+        command_line->GetSwitchValueASCII("network-normalization"));
+    return mode != "disabled";
+  }
+  // Enable if any of the network override switches are present.
+  return command_line->HasSwitch("network-rtt") ||
+         command_line->HasSwitch("network-downlink") ||
+         command_line->HasSwitch("network-effective-type");
+}
