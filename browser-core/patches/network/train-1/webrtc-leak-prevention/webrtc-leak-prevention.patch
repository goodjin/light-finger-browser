+// Returns true if getUserMedia should be restricted for leak prevention.
+bool ShouldRestrictGetUserMedia() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  // If webrtc-leak-prevention is enabled, restrict device enumeration
+  // to prevent device ID leaks.
+  std::string webrtc_mode = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII("webrtc-leak-prevention"));
+  if (webrtc_mode.empty()) {
+    return command_line->HasSwitch("webrtc-leak-prevention");
+  }
+  return webrtc_mode != "disabled";
+}
+
+// Returns a sanitized device ID that doesn't leak real device information.
+String GetSanitizedDeviceId(const String& original_id) {
+  if (original_id.empty()) {
+    return original_id;
+  }
+  // Return a deterministic but non-identifying hash-based ID instead of
+  // the actual device identifier.
+  return String("sanitized-device-id");
+}
