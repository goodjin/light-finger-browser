+// Returns true if WebRTC leak prevention is enabled via command line.
+bool IsWebRTCLeakPreventionEnabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  // Default behavior: if switch is present and not set to "disabled", enable.
+  std::string webrtc_mode = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII("webrtc-leak-prevention"));
+  if (webrtc_mode.empty()) {
+    // Default: enable leak prevention if switch is present without value.
+    return command_line->HasSwitch("webrtc-leak-prevention");
+  }
+  return webrtc_mode != "disabled";
+}
+
+// Returns true if we should force disable WebRTC entirely.
+bool IsWebRTCDisabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  return command_line->HasSwitch("disable-webrtc");
+}
