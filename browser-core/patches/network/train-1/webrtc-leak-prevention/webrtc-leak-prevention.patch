+bool RTCConfiguration::disable_ipv6() const {
+  // Check command line override for IPv6 leak prevention.
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (command_line &&
+      command_line->HasSwitch("webrtc-leak-prevention")) {
+    // When leak prevention is enabled, disable IPv6 by default to prevent
+    // local IP leaks through WebRTC ICE candidates.
+    return true;
+  }
+  return disable_ipv6_;
+}
+
+bool RTCConfiguration::disable_ip_v6_flow() const {
+  // Additional IPv6 flow prevention check.
+  if (disable_ipv6()) {
