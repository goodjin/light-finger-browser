 namespace blink {
 
+namespace {
+
+String PlatformOverrideFromCommandLine() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return String();
+  }
+  const std::string override_value =
+      command_line->GetSwitchValueASCII("platform");
+  if (override_value.empty()) {
+    return String();
+  }
+  return String::FromUtf8(override_value);
+}
+
+bool IsWebDriverDisabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  return command_line->HasSwitch("disable-webdriver") ||
+         command_line->HasSwitch("disable-automation");
+}
+
+}  // namespace
