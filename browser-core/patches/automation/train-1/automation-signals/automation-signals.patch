 namespace blink {

+namespace {
+
+bool IsWebDriverDisabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  // Check for explicit disable flag
+  if (command_line->HasSwitch("disable-webdriver")) {
+    return true;
+  }
+  // If automation is explicitly disabled, also hide webdriver
+  if (command_line->HasSwitch("disable-automation")) {
+    return true;
+  }
+  return false;
+}
+
+}  // namespace
