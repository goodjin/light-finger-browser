+// Check if fingerprint noise is enabled for input behavior randomization
+bool IsInputNoiseEnabled() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return false;
+  }
+  // Check if fingerprint-noise is explicitly disabled
+  std::string noise_value = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII("fingerprint-noise"));
+  if (!noise_value.empty() &&
+      (noise_value == "0" || noise_value == "false" ||
+       noise_value == "no")) {
+    return false;
+  }
+  // Check for explicit enable flag
+  if (command_line->HasSwitch("enable-input-noise")) {
+    return true;
+  }
+  return false;
+}
+
+// Get jitter range in milliseconds for event timestamp randomization
+// Returns 0 if noise is disabled
+int GetInputJitterRangeMs() {
+  if (!IsInputNoiseEnabled()) {
+    return 0;
+  }
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return 5;  // Default jitter range: 5ms
+  }
+  std::string jitter_value =
+      command_line->GetSwitchValueASCII("input-jitter-range-ms");
+  if (jitter_value.empty()) {
+    return 5;  // Default
+  }
+  int jitter = atoi(jitter_value.c_str());
+  if (jitter < 0 || jitter > 50) {
+    return 5;  // Clamp to reasonable range
+  }
+  return jitter;
+}
+
+// Apply timestamp jitter to make input events appear more human-like
+base::TimeTicks ApplyInputTimestampJitter(base::TimeTicks timestamp) {
+  int jitter_range = GetInputJitterRangeMs();
+  if (jitter_range == 0) {
+    return timestamp;
+  }
+  // Add random jitter in range [-jitter_range, +jitter_range] ms
+  int jitter_ms = base::RandInt(-jitter_range, jitter_range);
+  return timestamp + base::Milliseconds(jitter_ms);
+}
+
