+struct AudioFingerprintOverride {
+  bool enabled = false;
+  float offset = 0.0f;
+  float scale = 1.0f;
+};
+
+AudioFingerprintOverride BuildAudioFingerprintOverride() {
+  AudioFingerprintOverride override_value;
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return override_value;
+  }
+
+  double offset = 0.0;
+  double scale = 1.0;
+  bool has_override = false;
+  bool has_offset = false;
+
+  const std::string offset_value =
+      command_line->GetSwitchValueASCII("audio-fingerprint-offset");
+  if (!offset_value.empty() && base::StringToDouble(offset_value, &offset)) {
+    override_value.offset = static_cast<float>(offset);
+    has_override = true;
+    has_offset = true;
+  }
+
+  const std::string scale_value =
+      command_line->GetSwitchValueASCII("audio-fingerprint-scale");
+  if (!scale_value.empty() && base::StringToDouble(scale_value, &scale)) {
+    override_value.scale = static_cast<float>(scale);
+    has_override = true;
+  }
+
+  const std::string seed_value =
+      command_line->GetSwitchValueASCII("audio-fingerprint-seed");
+  if (!seed_value.empty()) {
+    int seed = 0;
+    if (base::StringToInt(seed_value, &seed)) {
+      if (!has_offset) {
+        override_value.offset =
+            static_cast<float>((seed % 1000) - 500) / 100000.0f;
+      }
+      has_override = true;
+    }
+  }
+
+  override_value.enabled = has_override;
+  return override_value;
+}
+
+const AudioFingerprintOverride& AudioFingerprintOverrideFromCommandLine() {
+  static AudioFingerprintOverride override_value =
+      BuildAudioFingerprintOverride();
+  return override_value;
+}
+
+void ApplyAudioFingerprintOverride(base::span<float> data,
+                                   const AudioFingerprintOverride& override) {
+  if (!override.enabled) {
+    return;
+  }
+  for (auto& sample : data) {
+    sample = sample * override.scale + override.offset;
+  }
+}
+
+void ApplyAudioFingerprintOverride(base::span<uint8_t> data,
+                                   const AudioFingerprintOverride& override) {
+  if (!override.enabled) {
+    return;
+  }
+  for (auto& sample : data) {
+    float adjusted =
+        static_cast<float>(sample) * override.scale + override.offset;
+    adjusted = std::clamp(adjusted, 0.0f, 255.0f);
+    sample = static_cast<uint8_t>(adjusted);
+  }
+}
+
