+const Vector<String>& FontAllowlistFromCommandLine() {
+  static base::NoDestructor<Vector<String>> allowlist;
+  static bool initialized = false;
+  if (initialized) {
+    return *allowlist;
+  }
+  initialized = true;
+
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return *allowlist;
+  }
+  const std::string allowlist_value =
+      command_line->GetSwitchValueASCII("font-allowlist");
+  if (allowlist_value.empty()) {
+    return *allowlist;
+  }
+  std::vector<std::string> entries = base::SplitString(
+      allowlist_value, ",", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+  for (const auto& entry : entries) {
+    allowlist->push_back(String::FromUtf8(entry));
+  }
+  return *allowlist;
+}
+
+bool IsFontAllowedByCommandLine(const Font& font) {
+  const Vector<String>& allowlist = FontAllowlistFromCommandLine();
+  if (allowlist.empty()) {
+    return true;
+  }
+  for (const FontFamily* family = &font.GetFontDescription().Family(); family;
+       family = family->Next()) {
+    if (family->FamilyIsGeneric()) {
+      continue;
+    }
+    String family_name = family->FamilyName();
+    for (const auto& allowed : allowlist) {
+      if (DeprecatedEqualIgnoringCase(family_name, allowed)) {
+        return true;
+      }
+    }
+  }
+  return false;
+}
+
+}  // namespace
