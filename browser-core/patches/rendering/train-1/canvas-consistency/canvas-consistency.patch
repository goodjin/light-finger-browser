+
+scoped_refptr<StaticBitmapImage> ApplyCanvasFingerprintNoiseIfNeeded(
+    scoped_refptr<StaticBitmapImage> image) {
+  uint64_t seed = 0;
+  if (!image || !GetCanvasFingerprintSeed(&seed)) {
+    return image;
+  }
+
+  PaintImage paint_image = image->PaintImageForCurrentFrame();
+  SkImageInfo info = paint_image.GetSkImageInfo();
+  if (info.isEmpty()) {
+    return image;
+  }
+
+  SkBitmap bitmap;
+  if (!bitmap.tryAllocPixels(info)) {
+    return image;
+  }
+  if (!paint_image.readPixels(info, bitmap.getPixels(), bitmap.rowBytes(), 0,
+                              0)) {
+    return image;
+  }
+
+  SkPixmap pixmap = bitmap.pixmap();
+  ApplyCanvasFingerprintNoise(&pixmap, seed, 0, 0);
+
+  sk_sp<SkData> data =
+      SkData::MakeWithCopy(pixmap.addr(), pixmap.computeByteSize());
+  if (!data) {
+    return image;
+  }
+
+  sk_sp<SkImage> sk_image =
+      SkImages::RasterFromData(info, std::move(data), pixmap.rowBytes());
+  if (!sk_image) {
+    return image;
+  }
+
+  scoped_refptr<StaticBitmapImage> noisy_image =
+      UnacceleratedStaticBitmapImage::Create(std::move(sk_image),
+                                             image->Orientation());
+  noisy_image->SetOriginClean(image->OriginClean());
+  return noisy_image;
+}
