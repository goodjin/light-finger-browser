+namespace {
+
+bool GetCanvasFingerprintSeed(uint64_t* seed_out) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line || !command_line->HasSwitch("fingerprint")) {
+    return false;
+  }
+
+  std::string seed_value = command_line->GetSwitchValueASCII("fingerprint");
+  uint64_t seed = 0;
+  if (!seed_value.empty()) {
+    if (!base::StringToUint64(seed_value, &seed)) {
+      seed = 1469598103934665603ULL;
+      for (unsigned char c : seed_value) {
+        seed ^= c;
+        seed *= 1099511628211ULL;
+      }
+    }
+  }
+
+  std::string noise_value = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII("fingerprint-noise"));
+  if (!noise_value.empty() &&
+      (noise_value == "0" || noise_value == "false" ||
+       noise_value == "no")) {
+    return false;
+  }
+
+  *seed_out = seed;
+  return true;
+}
+
+uint64_t MixCanvasFingerprintSeed(uint64_t seed, uint32_t x, uint32_t y) {
+  uint64_t value =
+      seed ^ (static_cast<uint64_t>(x) << 32) ^ y ^ 0x9e3779b97f4a7c15ULL;
+  value ^= value >> 33;
+  value *= 0xff51afd7ed558ccdULL;
+  value ^= value >> 33;
+  value *= 0xc4ceb9fe1a85ec53ULL;
+  value ^= value >> 33;
+  return value;
+}
+
+void ApplyCanvasFingerprintNoise(SkPixmap* pixmap,
+                                 int offset_x,
+                                 int offset_y) {
+  if (!pixmap || !pixmap->addr()) {
+    return;
+  }
+
+  uint64_t seed = 0;
+  if (!GetCanvasFingerprintSeed(&seed)) {
+    return;
+  }
+
+  const int bytes_per_pixel = pixmap->info().bytesPerPixel();
+  if (bytes_per_pixel < 4) {
+    return;
+  }
+
+  auto* data = static_cast<uint8_t*>(pixmap->writable_addr());
+  if (!data) {
+    return;
+  }
+
+  const int width = pixmap->width();
+  const int height = pixmap->height();
+  const size_t row_bytes = pixmap->rowBytes();
+  const size_t buffer_size = row_bytes * static_cast<size_t>(height);
+  auto buffer = UNSAFE_BUFFERS(base::span<uint8_t>(data, buffer_size));
+
+  for (int y = 0; y < height; ++y) {
+    const size_t row_offset = static_cast<size_t>(y) * row_bytes;
+    const int pixel_y = y + offset_y;
+    for (int x = 0; x < width; ++x) {
+      const size_t pixel_offset =
+          row_offset + static_cast<size_t>(x) * bytes_per_pixel;
+      if (pixel_offset + 2 >= buffer.size()) {
+        continue;
+      }
+      auto pixel = buffer.subspan(pixel_offset,
+                                  static_cast<size_t>(bytes_per_pixel));
+      uint64_t mix = MixCanvasFingerprintSeed(
+          seed, static_cast<uint32_t>(x + offset_x),
+          static_cast<uint32_t>(pixel_y));
+      uint8_t noise = static_cast<uint8_t>(mix & 0x07);
+      pixel[0] = static_cast<uint8_t>((pixel[0] & 0xFE) | (noise & 0x1));
+      pixel[1] =
+          static_cast<uint8_t>((pixel[1] & 0xFE) | ((noise >> 1) & 0x1));
+      pixel[2] =
+          static_cast<uint8_t>((pixel[2] & 0xFE) | ((noise >> 2) & 0x1));
+    }
+  }
+}
