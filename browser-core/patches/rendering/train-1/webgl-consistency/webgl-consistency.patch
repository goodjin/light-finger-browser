+constexpr GLenum kUnmaskedVendorWebGL = 0x9245;
+constexpr GLenum kUnmaskedRendererWebGL = 0x9246;
+
+bool WebGLExtensionAllowedByOverride(const WebGLOverrideConfig& config,
+                                     const String& name) {
+  if (config.extensions.empty()) {
+    return true;
+  }
+  for (const auto& extension : config.extensions) {
+    if (DeprecatedEqualIgnoringCase(extension, name)) {
+      return true;
+    }
+  }
+  return false;
+}
