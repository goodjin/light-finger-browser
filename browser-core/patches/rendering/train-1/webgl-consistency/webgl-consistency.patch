+struct WebGLContextAttributeOverrides {
+  std::optional<bool> alpha;
+  std::optional<bool> depth;
+  std::optional<bool> stencil;
+  std::optional<bool> antialias;
+  std::optional<bool> premultiplied_alpha;
+  std::optional<bool> preserve_drawing_buffer;
+  std::optional<bool> fail_if_major_performance_caveat;
+  std::optional<bool> desynchronized;
+  std::optional<bool> xr_compatible;
+};
+
+struct WebGLOverrideConfig {
+  String vendor;
+  String renderer;
+  Vector<String> extensions;
+  HashMap<GLenum, GLint> parameter_overrides;
+  bool has_precision_override = false;
+  GLint precision_range_min = 0;
+  GLint precision_range_max = 0;
+  GLint precision = 0;
+  WebGLContextAttributeOverrides context_attributes;
+};
+
+std::optional<bool> ParseBoolOverride(const std::string& value) {
+  if (value == "1" || base::EqualsCaseInsensitiveASCII(value, "true")) {
+    return true;
+  }
+  if (value == "0" || base::EqualsCaseInsensitiveASCII(value, "false")) {
+    return false;
+  }
+  return std::nullopt;
+}
+
+bool ParseWebGLParameterName(const std::string& token, GLenum* pname) {
+  std::string normalized = base::ToUpperASCII(token);
+  base::ReplaceChars(normalized, "-", "_", &normalized);
+  if (normalized == "MAX_TEXTURE_SIZE") {
+    *pname = GL_MAX_TEXTURE_SIZE;
+    return true;
+  }
+  if (normalized == "MAX_RENDERBUFFER_SIZE") {
+    *pname = GL_MAX_RENDERBUFFER_SIZE;
+    return true;
+  }
+  if (normalized == "MAX_VERTEX_ATTRIBS") {
+    *pname = GL_MAX_VERTEX_ATTRIBS;
+    return true;
+  }
+  if (normalized == "MAX_VERTEX_UNIFORM_VECTORS") {
+    *pname = GL_MAX_VERTEX_UNIFORM_VECTORS;
+    return true;
+  }
+  if (normalized == "MAX_FRAGMENT_UNIFORM_VECTORS") {
+    *pname = GL_MAX_FRAGMENT_UNIFORM_VECTORS;
+    return true;
+  }
+  if (normalized == "MAX_VARYING_VECTORS") {
+    *pname = GL_MAX_VARYING_VECTORS;
+    return true;
+  }
+  if (normalized == "MAX_COMBINED_TEXTURE_IMAGE_UNITS") {
+    *pname = GL_MAX_COMBINED_TEXTURE_IMAGE_UNITS;
+    return true;
+  }
+
+  int parsed_value = 0;
+  if (base::HexStringToInt(token, &parsed_value) ||
+      base::StringToInt(token, &parsed_value)) {
+    *pname = static_cast<GLenum>(parsed_value);
+    return true;
+  }
+
+  return false;
+}
+
+void PopulateWebGLOverrides(WebGLOverrideConfig* config) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return;
+  }
+
+  const std::string vendor_override =
+      command_line->GetSwitchValueASCII("webgl-vendor");
+  if (!vendor_override.empty()) {
+    config->vendor = String::FromUtf8(vendor_override);
+  }
+
+  const std::string renderer_override =
+      command_line->GetSwitchValueASCII("webgl-renderer");
+  if (!renderer_override.empty()) {
+    config->renderer = String::FromUtf8(renderer_override);
+  }
+
+  const std::string extensions_override =
+      command_line->GetSwitchValueASCII("webgl-extensions");
+  if (!extensions_override.empty()) {
+    std::vector<std::string> extensions = base::SplitString(
+        extensions_override, ",", base::TRIM_WHITESPACE,
+        base::SPLIT_WANT_NONEMPTY);
+    for (const auto& extension : extensions) {
+      config->extensions.push_back(String::FromUtf8(extension));
+    }
+  }
+
+  const std::string parameter_override =
+      command_line->GetSwitchValueASCII("webgl-parameters");
+  if (!parameter_override.empty()) {
+    std::vector<std::string> entries = base::SplitString(
+        parameter_override, ",;", base::TRIM_WHITESPACE,
+        base::SPLIT_WANT_NONEMPTY);
+    for (const auto& entry : entries) {
+      std::vector<std::string> parts = base::SplitString(
+          entry, "=", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+      if (parts.size() != 2) {
+        continue;
+      }
+      GLenum pname = 0;
+      if (!ParseWebGLParameterName(parts[0], &pname)) {
+        continue;
+      }
+      int value = 0;
+      if (!base::StringToInt(parts[1], &value)) {
+        continue;
+      }
+      config->parameter_overrides.Set(pname, value);
+    }
+  }
+
+  const std::string precision_override =
+      command_line->GetSwitchValueASCII("webgl-precision");
+  if (!precision_override.empty()) {
+    std::vector<std::string> parts = base::SplitString(
+        precision_override, ",:", base::TRIM_WHITESPACE,
+        base::SPLIT_WANT_NONEMPTY);
+    if (parts.size() == 3) {
+      int range_min = 0;
+      int range_max = 0;
+      int precision = 0;
+      if (base::StringToInt(parts[0], &range_min) &&
+          base::StringToInt(parts[1], &range_max) &&
+          base::StringToInt(parts[2], &precision)) {
+        config->has_precision_override = true;
+        config->precision_range_min = range_min;
+        config->precision_range_max = range_max;
+        config->precision = precision;
+      }
+    }
+  }
+
+  const std::string context_attributes_override =
+      command_line->GetSwitchValueASCII("webgl-context-attributes");
+  if (!context_attributes_override.empty()) {
+    std::vector<std::string> entries = base::SplitString(
+        context_attributes_override, ",", base::TRIM_WHITESPACE,
+        base::SPLIT_WANT_NONEMPTY);
+    for (const auto& entry : entries) {
+      std::vector<std::string> parts = base::SplitString(
+          entry, "=", base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY);
+      if (parts.size() != 2) {
+        continue;
+      }
+      std::string key = base::ToLowerASCII(parts[0]);
+      std::optional<bool> value = ParseBoolOverride(parts[1]);
+      if (!value.has_value()) {
+        continue;
+      }
+      if (key == "alpha") {
+        config->context_attributes.alpha = value;
+      } else if (key == "depth") {
+        config->context_attributes.depth = value;
+      } else if (key == "stencil") {
+        config->context_attributes.stencil = value;
+      } else if (key == "antialias") {
+        config->context_attributes.antialias = value;
+      } else if (key == "premultipliedalpha") {
+        config->context_attributes.premultiplied_alpha = value;
+      } else if (key == "preservedrawingbuffer") {
+        config->context_attributes.preserve_drawing_buffer = value;
+      } else if (key == "failifmajorperformancecaveat") {
+        config->context_attributes.fail_if_major_performance_caveat = value;
+      } else if (key == "desynchronized") {
+        config->context_attributes.desynchronized = value;
+      } else if (key == "xrcompatible") {
+        config->context_attributes.xr_compatible = value;
+      }
+    }
+  }
+}
+
+const WebGLOverrideConfig& WebGLOverridesFromCommandLine() {
+  static base::NoDestructor<WebGLOverrideConfig> config;
+  static bool initialized = false;
+  if (!initialized) {
+    initialized = true;
+    PopulateWebGLOverrides(config.get());
+  }
+  return *config;
+}
