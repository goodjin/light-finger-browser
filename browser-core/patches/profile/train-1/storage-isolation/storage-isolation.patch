+// Storage partition key component derived from fingerprint seed.
+// This ensures storage is isolated per browser instance based on
+// the fingerprint seed, preventing cross-instance storage leakage.
+std::string GetFingerprintBasedStorageKey() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return std::string();
+  }
+
+  const std::string fingerprint_seed =
+      command_line->GetSwitchValueASCII("fingerprint");
+  if (fingerprint_seed.empty()) {
+    return std::string();
+  }
+
+  // Create a deterministic key component from the fingerprint seed.
+  // Using FNV-1a hash for deterministic derivation.
+  uint64_t hash = 1469598103934665603ULL;  // FNV offset basis
+  for (unsigned char c : fingerprint_seed) {
+    hash ^= static_cast<uint64_t>(c);
+    hash *= 1099511628211ULL;  // FNV prime
+  }
+
+  return base::StringPrintf("%llx", static_cast<unsigned long long>(hash));
+}
+
+// Generate a deterministic storage bucket name based on fingerprint seed.
+std::string GetFingerprintBasedBucketName() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return std::string();
+  }
+
+  const std::string bucket_id =
+      command_line->GetSwitchValueASCII("storage-bucket-id");
+  if (!bucket_id.empty()) {
+    return bucket_id;
+  }
+
+  const std::string fingerprint_seed =
+      command_line->GetSwitchValueASCII("fingerprint");
+  if (fingerprint_seed.empty()) {
+    return std::string();
+  }
+
+  // Create a deterministic bucket ID from the fingerprint seed.
+  uint64_t hash = 1469598103934665603ULL;
+  for (unsigned char c : fingerprint_seed) {
+    hash ^= static_cast<uint64_t>(c);
+    hash *= 1099511628211ULL;
+  }
+
+  return base::StringPrintf("lfb-bucket-%llx",
+                           static_cast<unsigned long long>(hash));
+}
+
