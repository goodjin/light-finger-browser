+// Permission state normalization mapping.
+// Maps permission types to deterministic states based on command-line flags.
+mojom::PermissionState GetNormalizedPermissionState(
+    const String& permission_name) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return mojom::PermissionState::ASK;  // Default to prompt.
+  }
+
+  // Check for explicit permission override in format: --permission-{name}={state}
+  // where state is: granted, denied, or prompt.
+  std::string switch_name = "permission-";
+  switch_name += permission_name.Ascii();
+
+  const std::string override_value =
+      base::ToLowerASCII(command_line->GetSwitchValueASCII(switch_name));
+
+  if (!override_value.empty()) {
+    if (override_value == "granted" || override_value == "allow") {
+      return mojom::PermissionState::GRANTED;
+    }
+    if (override_value == "denied" || override_value == "block") {
+      return mojom::PermissionState::DENIED;
+    }
+    if (override_value == "prompt" || override_value == "ask") {
+      return mojom::PermissionState::ASK;
+    }
+  }
+
+  // Default normalized states for common permissions.
+  // These provide deterministic behavior while being reasonable defaults.
+  if (permission_name == "geolocation") {
+    return mojom::PermissionState::ASK;
+  }
+  if (permission_name == "notifications") {
+    return mojom::PermissionState::DENIED;
+  }
+  if (permission_name == "push") {
+    return mojom::PermissionState::ASK;
+  }
+  if (permission_name == "midi") {
+    return mojom::PermissionState::GRANTED;
+  }
+  if (permission_name == "midi-sysex") {
+    return mojom::PermissionState::DENIED;
+  }
+  if (permission_name == "storage-access") {
+    return mojom::PermissionState::ASK;
+  }
+  if (permission_name == "accessibility-events") {
+    return mojom::PermissionState::ASK;
+  }
+  if (permission_name == "clipboard-read") {
+    return mojom::PermissionState::DENIED;
+  }
+  if (permission_name == "clipboard-write") {
+    return mojom::PermissionState::GRANTED;
+  }
+  if (permission_name == "payment") {
+    return mojom::PermissionState::ASK;
+  }
+
+  // Default to prompt for unknown permissions.
+  return mojom::PermissionState::ASK;
+}
+
+// Returns whether permission states should be normalized.
+bool ShouldNormalizePermissions() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return true;  // Default to normalized if no command line.
+  }
+
+  const std::string normalize_value =
+      base::ToLowerASCII(
+          command_line->GetSwitchValueASCII("normalize-permissions"));
+  if (normalize_value.empty()) {
+    return true;  // Default to normalized.
+  }
+  // Normalization is disabled only if explicitly set to "0", "false", or "no".
+  return !(normalize_value == "0" || normalize_value == "false" ||
+           normalize_value == "no");
+}
