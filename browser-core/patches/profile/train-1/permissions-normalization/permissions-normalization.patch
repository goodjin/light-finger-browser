+ScriptPromise Permissions::queryNormalizePermissionState(
+    ScriptState* script_state,
+    const String& permission_name) {
+  // Check if normalization is enabled.
+  if (!ShouldNormalizePermissions()) {
+    return query(script_state, permission_name);
+  }
+
+  // Return a promise that resolves to the normalized state.
+  auto* resolver = MakeGarbageCollected<ScriptPromiseResolver>(
+      script_state);
+
+  // Determine normalized state.
+  mojom::PermissionState normalized_state =
+      GetNormalizedPermissionState(permission_name);
+
+  // Convert state to status (ASK = prompt).
+  mojom::PermissionStatus status = mojom::PermissionStatus::ASK;
+  switch (normalized_state) {
+    case mojom::PermissionState::GRANTED:
+      status = mojom::PermissionStatus::GRANTED;
+      break;
+    case mojom::PermissionState::DENIED:
+      status = mojom::PermissionStatus::DENIED;
+      break;
+    case mojom::PermissionState::ASK:
+    default:
+      status = mojom::PermissionStatus::ASK;
+      break;
+  }
+
+  resolver->Resolve(status);
+  return resolver->Promise();
+}
