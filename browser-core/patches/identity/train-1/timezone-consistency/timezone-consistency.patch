+std::unique_ptr<TimeZoneController::TimeZoneOverride>&
+CommandLineTimezoneOverride() {
+  static base::NoDestructor<std::unique_ptr<TimeZoneController::TimeZoneOverride>>
+      handle;
+  return *handle;
+}
+
+void ApplyCommandLineTimezoneOverride() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return;
+  }
+  const std::string timezone_value =
+      command_line->GetSwitchValueASCII("timezone");
+  if (timezone_value.empty()) {
+    return;
+  }
+  auto result =
+      TimeZoneController::SetTimeZoneOverride(String::FromUtf8(timezone_value));
+  if (result.status == TimeZoneController::TimeZoneOverrideStatus::kSuccess &&
+      result.handle) {
+    CommandLineTimezoneOverride() = std::move(result.handle);
+  }
+}
+
 }  // namespace
 
