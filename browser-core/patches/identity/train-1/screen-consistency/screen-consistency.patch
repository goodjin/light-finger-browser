 namespace blink {
 
+namespace {
+bool ParseIntSwitch(const char* switch_name, int* out) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line)
+    return false;
+  const std::string value = command_line->GetSwitchValueASCII(switch_name);
+  if (value.empty())
+    return false;
+  return base::StringToInt(value, out);
+}
+
+bool ParsePositiveIntSwitch(const char* switch_name, int* out) {
+  int value = 0;
+  if (!ParseIntSwitch(switch_name, &value) || value <= 0)
+    return false;
+  *out = value;
+  return true;
+}
+
+bool ParseNonNegativeIntSwitch(const char* switch_name, int* out) {
+  int value = 0;
+  if (!ParseIntSwitch(switch_name, &value) || value < 0)
+    return false;
+  *out = value;
+  return true;
+}
+
+bool GetColorDepthOverride(unsigned* out) {
+  int value = 0;
+  if (!ParseIntSwitch("screen-color-depth", &value))
+    return false;
+  if (value != 24 && value != 30 && value != 32)
+    return false;
+  *out = static_cast<unsigned>(value);
+  return true;
+}
+
+}  // namespace
