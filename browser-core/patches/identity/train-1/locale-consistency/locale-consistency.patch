+String LocaleOverrideFromCommandLine() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line) {
+    return String();
+  }
+  const std::string locale_value =
+      command_line->GetSwitchValueASCII("locale");
+  if (locale_value.empty()) {
+    return String();
+  }
+  return String::FromUtf8(locale_value);
+}
