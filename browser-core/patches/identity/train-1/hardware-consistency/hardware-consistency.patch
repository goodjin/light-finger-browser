diff --git a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
index f5c0db2d1b58d..3ba1c31528cfa 100644
--- a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
+++ b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
@@ -4,11 +4,35 @@
 
 #include "third_party/blink/renderer/core/frame/navigator_concurrent_hardware.h"
 
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
 #include "base/system/sys_info.h"
 
 namespace blink {
 
+namespace {
+bool GetHardwareConcurrencyOverride(unsigned* out) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line)
+    return false;
+  const std::string value =
+      command_line->GetSwitchValueASCII("hardware-concurrency");
+  if (value.empty())
+    return false;
+  int parsed = 0;
+  if (!base::StringToInt(value, &parsed) || parsed <= 0)
+    return false;
+  *out = static_cast<unsigned>(parsed);
+  return true;
+}
+
+}  // namespace
+
 unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  unsigned override_value = 0;
+  if (GetHardwareConcurrencyOverride(&override_value))
+    return override_value;
   return static_cast<unsigned>(base::SysInfo::NumberOfProcessors());
 }
 
diff --git a/third_party/blink/renderer/core/frame/navigator_device_memory.cc b/third_party/blink/renderer/core/frame/navigator_device_memory.cc
index 2876aad29853b..f271a48689070 100644
--- a/third_party/blink/renderer/core/frame/navigator_device_memory.cc
+++ b/third_party/blink/renderer/core/frame/navigator_device_memory.cc
@@ -4,6 +4,10 @@
 
 #include "third_party/blink/renderer/core/frame/navigator_device_memory.h"
 
+#include <cmath>
+
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
 #include "third_party/blink/public/common/device_memory/approximated_device_memory.h"
 #include "third_party/blink/public/common/privacy_budget/identifiability_metric_builder.h"
 #include "third_party/blink/public/common/privacy_budget/identifiability_metrics.h"
@@ -13,7 +17,39 @@
 
 namespace blink {
 
+namespace {
+bool IsAllowedDeviceMemoryValue(double value) {
+  constexpr double kAllowedValues[] = {0.25, 0.5, 1, 2, 4, 8, 16, 32};
+  for (double allowed : kAllowedValues) {
+    if (std::abs(value - allowed) < 0.001)
+      return true;
+  }
+  return false;
+}
+
+bool GetDeviceMemoryOverride(float* out) {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line)
+    return false;
+  const std::string value = command_line->GetSwitchValueASCII("device-memory");
+  if (value.empty())
+    return false;
+  double parsed = 0.0;
+  if (!base::StringToDouble(value, &parsed) || parsed <= 0.0)
+    return false;
+  if (!IsAllowedDeviceMemoryValue(parsed))
+    return false;
+  *out = static_cast<float>(parsed);
+  return true;
+}
+
+}  // namespace
+
 float NavigatorDeviceMemory::deviceMemory() const {
+  float override_value = 0.0f;
+  if (GetDeviceMemoryOverride(&override_value))
+    return override_value;
   return ApproximatedDeviceMemory::GetApproximatedDeviceMemory();
 }
 
