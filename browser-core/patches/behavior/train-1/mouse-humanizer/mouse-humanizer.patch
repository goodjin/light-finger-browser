+double MouseEvent::screenX() const {
+  uint64_t seed = 0;
+  if (GetMouseBehaviorSeed(&seed)) {
+    g_mouse_event_counter++;
+    double jitter = GetMousePositionJitter(seed, g_mouse_event_counter, 1.5);
+    return std::floor(screen_x_ + jitter);
+  }
+  return std::floor(screen_x_);
+}
+
+double MouseEvent::screenY() const {
+  uint64_t seed = 0;
+  if (GetMouseBehaviorSeed(&seed)) {
+    double jitter = GetMousePositionJitter(seed, g_mouse_event_counter, 1.5);
+    return std::floor(screen_y_ + jitter);
+  }
+  return std::floor(screen_y_);
+}
+
+double MouseEvent::clientX() const {
