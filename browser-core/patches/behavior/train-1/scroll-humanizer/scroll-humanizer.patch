+
+double WheelEvent::timing() const {
+  uint64_t seed = 0;
+  if (GetBehaviorSeed(&seed)) {
+    g_scroll_event_counter++;
+    int64_t jitter = GetScrollCadenceJitter(seed, g_scroll_event_counter, 5000);
+    double base_timing = PlatformEvent::timing();
