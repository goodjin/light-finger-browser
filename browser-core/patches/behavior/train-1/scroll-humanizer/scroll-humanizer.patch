+float WheelEvent::wheelDeltaX() const {
+  uint64_t seed = 0;
+  if (GetBehaviorSeed(&seed)) {
+    g_scroll_event_counter++;
+    double multiplier = GetScrollInertiaMultiplier(seed, g_scroll_event_counter);
+    return static_cast<float>(PlatformEvent::wheelDeltaX() * multiplier);
+  }
+  return PlatformEvent::wheelDeltaX();
+}
